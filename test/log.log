  outputs : rb_raw (complex), rt (complex), rb_used policy(phiB=pi) = -abs(rb_raw)
  grid    : lam_nm=[450.0, 550.0, 650.0], u in {0.0,0.7}, pol in {TE(0),TM(1)}
  criterion: rb_raw/rt atol=1e-10 OR rtol=1e-10;  rb_used policy atol=1e-12

[CHECK] BT rb_raw vs PyMoosh (pol=0)
